# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/agenthub

# Redis (BullMQ queue backend)
REDIS_URL=redis://localhost:6379

# App
PORT=4000
NODE_ENV=development

# JWT — SIWE sessions
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRY=7d

# Circle x402 Gateway
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# Your platform's Ethereum wallet address (receives x402 payments)
SELLER_ADDRESS=0xYourPlatformWalletAddress

# Platform fee in basis points (200 = 2%)
PLATFORM_FEE_BPS=200

# CORS — frontend origin
FRONTEND_URL=http://localhost:3000

# Logging (log | error | warn | debug | verbose)
LOG_LEVEL=log
