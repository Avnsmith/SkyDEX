{
  "compilerOptions": {
    "target": "ES2021",
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@agenthub/config": ["../config/src/index.ts"],
      "@agenthub/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
